{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "simple",
  "include-component-in-tag": false,
  "changelog-sections": [
    { "type": "feat", "section": "新機能" },
    { "type": "fix", "section": "バグ修正" },
    { "type": "perf", "section": "パフォーマンス" },
    { "type": "refactor", "section": "リファクタリング" },
    { "type": "docs", "section": "ドキュメント" },
    { "type": "style", "section": "UI・スタイル", "hidden": true },
    { "type": "build", "section": "ビルド", "hidden": true },
    { "type": "ci", "section": "CI", "hidden": true },
    { "type": "test", "section": "テスト", "hidden": true },
    { "type": "chore", "section": "その他", "hidden": true }
  ],
  "packages": {
    ".": {
      "package-name": "labolabo",
      "changelog-path": "CHANGELOG.md",
      "extra-files": [
        {
          "type": "generic",
          "path": "Config/Version.xcconfig"
        }
      ]
    }
  }
}
